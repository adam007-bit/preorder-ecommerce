{
  "hosting": {
    "public": "public",
    "rewrites": [
      { "source": "/api/products", "function": "products" },
      { "source": "/api/stock", "function": "stock" },
      { "source": "/api/orders", "function": "orders" },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "functions": {
    "source": "functions",
    "codebase": "default",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log"
    ]
  }
}